# Supabase Postgres connection
# Usa Transaction Pooler en Supabase para evitar limites de clientes por sesion
SUPABASE_DB_URL=jdbc:postgresql://aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&prepareThreshold=0
SUPABASE_DB_USER=postgres.xxxxxxxxxxxxx
SUPABASE_DB_PASSWORD=REEMPLAZAR_CON_TU_PASSWORD
